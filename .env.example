# ============================================================
# CDC Pipeline - Environment Variables
# ============================================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control
# ============================================================

# --- PostgreSQL Source Database ---
SOURCE_PG_HOST=postgres-source
SOURCE_PG_PORT=5432
SOURCE_PG_DB=source_db
SOURCE_PG_USER=cdc_user
SOURCE_PG_PASSWORD=cdc_password
SOURCE_PG_REPLICATION_SLOT=cdc_slot

# --- PostgreSQL Target Database ---
TARGET_PG_HOST=postgres-target
TARGET_PG_PORT=5433
TARGET_PG_DB=target_db
TARGET_PG_USER=target_user
TARGET_PG_PASSWORD=target_password

# --- Apache Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_PREFIX=cdc.source.public
KAFKA_CONSUMER_GROUP=cdc-consumer-group
KAFKA_NUM_PARTITIONS=3
KAFKA_REPLICATION_FACTOR=1

# --- MinIO (S3-Compatible Storage) ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_BRONZE=cdc-bronze
MINIO_USE_SSL=false

# --- Prometheus ---
PROMETHEUS_PORT=9090
METRICS_PORT=8000

# --- Grafana ---
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# --- Airflow ---
AIRFLOW_PORT=8080
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW__CORE__FERNET_KEY=your-fernet-key-here

# --- Superset ---
SUPERSET_PORT=8088
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin

# --- Pipeline Configuration ---
CONSUMER_BATCH_SIZE=100
CONSUMER_FLUSH_INTERVAL_MS=500
CDC_POLL_INTERVAL_MS=100
DLQ_TOPIC=cdc.dead-letter-queue
